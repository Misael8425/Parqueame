{
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "scripts": {
    "start": "concurrently \"npm --prefix backend start\" \"npm --prefix frontend start\"",
    "start:backend": "npm --prefix backend start",
    "start:frontend": "npm --prefix frontend start",
    "build": "npm --prefix frontend run build"
  }
}
